{
  "version": 1,
  "name": "economy",
  "description": "Economía declarativa: movimientos de oro del jugador y deudas, sin item de por medio (para comprar items con stock está el plugin commerce). Eventos que consume: 'gold_granted' {amount, from?, reason?} cuando alguien paga o recompensa al jugador; 'payment_offered' {amount, to?, reason?} cuando el jugador paga suelto (si no hay oro suficiente es no-op y se emite 'payment_rejected'; si se cobra, 'payment_completed'); 'gold_stolen' {amount, by?, reason?} para robos o pérdidas (el oro nunca baja de 0; 'gold_lost' informa de lo realmente perdido); 'debt_created' {debt_id, amount, creditor, debtor?, reason?} registra una deuda viva del jugador; 'debt_payment_offered' {debt_id, amount} la abona con oro (sobrepago capeado a lo que queda; al llegar a 0 se emite 'debt_settled' y la deuda desaparece); 'debt_forgiven' {debt_id, reason?} la condona. Una deuda de un NPC hacia el jugador se resuelve con gold_granted + debt_forgiven. El slice guarda las deudas vivas y un ledger con las últimas 8 transacciones. La unidad 'gold' es mecánica: la moneda narrativa (dineros, coronas...) la pone la prosa.",
  "origin": {
    "author": "developer",
    "rationale": "Plugin economy v1: surgido del playtest narrativo de toledo_1200 (pagos de NPCs, robo, deuda con Yishaq) — el motor no podía tocar player.gold fuera de las compras de commerce."
  },
  "slice": {
    "schema": {
      "type": "object",
      "properties": {
        "debts": { "type": "object" },
        "ledger": { "type": "array" },
        "ledger_seq": { "type": "number" }
      }
    },
    "initial": { "debts": {}, "ledger": [], "ledger_seq": 0 }
  },
  "reads": ["player.gold"],
  "writes": ["player.gold"],
  "events_consumed": [
    {
      "type": "gold_granted",
      "when": { "op": "gt", "path": "event.amount", "value": 0 },
      "do": [
        { "op": "inc", "path": "player.gold", "value": "event.amount" },
        { "op": "inc", "path": "slice.ledger_seq", "value": 1 },
        {
          "op": "push",
          "path": "slice.ledger",
          "value": {
            "seq": "slice.ledger_seq",
            "kind": "grant",
            "amount": "event.amount",
            "with": "coalesce(event.from, null)",
            "note": "coalesce(event.reason, null)"
          }
        },
        {
          "op": "set",
          "path": "slice.ledger",
          "value": {
            "filter": "slice.ledger",
            "where": { "op": "gt", "path": "_.seq", "value": "slice.ledger_seq - 8" }
          }
        }
      ]
    },
    {
      "type": "payment_offered",
      "when": {
        "all": [
          { "op": "gt", "path": "event.amount", "value": 0 },
          { "op": "lt", "path": "player.gold", "value": "event.amount" }
        ]
      },
      "do": [
        { "op": "inc", "path": "slice.ledger_seq", "value": 1 },
        {
          "op": "push",
          "path": "slice.ledger",
          "value": {
            "seq": "slice.ledger_seq",
            "kind": "payment_rejected",
            "amount": "event.amount",
            "with": "coalesce(event.to, null)",
            "note": "coalesce(event.reason, null)"
          }
        },
        {
          "op": "set",
          "path": "slice.ledger",
          "value": {
            "filter": "slice.ledger",
            "where": { "op": "gt", "path": "_.seq", "value": "slice.ledger_seq - 8" }
          }
        },
        {
          "op": "emit_event",
          "value": {
            "type": "payment_rejected",
            "payload": {
              "to": "coalesce(event.to, null)",
              "amount": "event.amount",
              "gold_available": "player.gold"
            }
          }
        }
      ]
    },
    {
      "type": "payment_offered",
      "when": {
        "all": [
          { "op": "gt", "path": "event.amount", "value": 0 },
          { "op": "gte", "path": "player.gold", "value": "event.amount" }
        ]
      },
      "do": [
        { "op": "dec", "path": "player.gold", "value": "event.amount" },
        { "op": "inc", "path": "slice.ledger_seq", "value": 1 },
        {
          "op": "push",
          "path": "slice.ledger",
          "value": {
            "seq": "slice.ledger_seq",
            "kind": "payment",
            "amount": "event.amount",
            "with": "coalesce(event.to, null)",
            "note": "coalesce(event.reason, null)"
          }
        },
        {
          "op": "set",
          "path": "slice.ledger",
          "value": {
            "filter": "slice.ledger",
            "where": { "op": "gt", "path": "_.seq", "value": "slice.ledger_seq - 8" }
          }
        },
        {
          "op": "emit_event",
          "value": {
            "type": "payment_completed",
            "payload": {
              "to": "coalesce(event.to, null)",
              "amount": "event.amount",
              "gold_remaining": "player.gold"
            }
          }
        }
      ]
    },
    {
      "type": "gold_stolen",
      "when": { "op": "gt", "path": "event.amount", "value": 0 },
      "do": [
        { "op": "inc", "path": "slice.ledger_seq", "value": 1 },
        {
          "op": "push",
          "path": "slice.ledger",
          "value": {
            "seq": "slice.ledger_seq",
            "kind": "loss",
            "amount": "min(player.gold, event.amount)",
            "with": "coalesce(event.by, null)",
            "note": "coalesce(event.reason, null)"
          }
        },
        {
          "op": "set",
          "path": "slice.ledger",
          "value": {
            "filter": "slice.ledger",
            "where": { "op": "gt", "path": "_.seq", "value": "slice.ledger_seq - 8" }
          }
        },
        {
          "op": "emit_event",
          "value": {
            "type": "gold_lost",
            "payload": {
              "amount": "min(player.gold, event.amount)",
              "by": "coalesce(event.by, null)"
            }
          }
        },
        { "op": "set", "path": "player.gold", "value": "max(0, player.gold - event.amount)" }
      ]
    },
    {
      "type": "debt_created",
      "when": {
        "all": [
          { "op": "has", "path": "event.debt_id" },
          { "op": "gt", "path": "event.amount", "value": 0 },
          { "not": { "op": "has", "path": "slice.debts.{event.debt_id}" } }
        ]
      },
      "do": [
        {
          "op": "set",
          "path": "slice.debts.{event.debt_id}",
          "value": {
            "debt_id": "event.debt_id",
            "debtor": "coalesce(event.debtor, 'player')",
            "creditor": "coalesce(event.creditor, null)",
            "amount": "event.amount",
            "reason": "coalesce(event.reason, null)"
          }
        },
        { "op": "inc", "path": "slice.ledger_seq", "value": 1 },
        {
          "op": "push",
          "path": "slice.ledger",
          "value": {
            "seq": "slice.ledger_seq",
            "kind": "debt_created",
            "amount": "event.amount",
            "with": "coalesce(event.creditor, null)",
            "note": "coalesce(event.reason, null)"
          }
        },
        {
          "op": "set",
          "path": "slice.ledger",
          "value": {
            "filter": "slice.ledger",
            "where": { "op": "gt", "path": "_.seq", "value": "slice.ledger_seq - 8" }
          }
        }
      ]
    },
    {
      "type": "debt_payment_offered",
      "when": {
        "all": [
          { "op": "has", "path": "event.debt_id" },
          { "op": "has", "path": "slice.debts.{event.debt_id}" },
          { "op": "eq", "path": "slice.debts.{event.debt_id}.debtor", "value": "'player'" },
          { "op": "gt", "path": "event.amount", "value": 0 },
          {
            "op": "lt",
            "path": "player.gold",
            "value": "min(event.amount, slice.debts.{event.debt_id}.amount)"
          }
        ]
      },
      "do": [
        { "op": "inc", "path": "slice.ledger_seq", "value": 1 },
        {
          "op": "push",
          "path": "slice.ledger",
          "value": {
            "seq": "slice.ledger_seq",
            "kind": "payment_rejected",
            "amount": "min(event.amount, slice.debts.{event.debt_id}.amount)",
            "with": "slice.debts.{event.debt_id}.creditor",
            "note": "coalesce(event.reason, null)"
          }
        },
        {
          "op": "set",
          "path": "slice.ledger",
          "value": {
            "filter": "slice.ledger",
            "where": { "op": "gt", "path": "_.seq", "value": "slice.ledger_seq - 8" }
          }
        },
        {
          "op": "emit_event",
          "value": {
            "type": "payment_rejected",
            "payload": {
              "debt_id": "event.debt_id",
              "to": "slice.debts.{event.debt_id}.creditor",
              "amount": "min(event.amount, slice.debts.{event.debt_id}.amount)",
              "gold_available": "player.gold"
            }
          }
        }
      ]
    },
    {
      "type": "debt_payment_offered",
      "when": {
        "all": [
          { "op": "has", "path": "event.debt_id" },
          { "op": "has", "path": "slice.debts.{event.debt_id}" },
          { "op": "eq", "path": "slice.debts.{event.debt_id}.debtor", "value": "'player'" },
          { "op": "gt", "path": "event.amount", "value": 0 },
          {
            "op": "gte",
            "path": "player.gold",
            "value": "min(event.amount, slice.debts.{event.debt_id}.amount)"
          }
        ]
      },
      "do": [
        { "op": "inc", "path": "slice.ledger_seq", "value": 1 },
        {
          "op": "push",
          "path": "slice.ledger",
          "value": {
            "seq": "slice.ledger_seq",
            "kind": "debt_payment",
            "amount": "min(event.amount, slice.debts.{event.debt_id}.amount)",
            "with": "slice.debts.{event.debt_id}.creditor",
            "note": "coalesce(event.reason, null)"
          }
        },
        {
          "op": "set",
          "path": "slice.ledger",
          "value": {
            "filter": "slice.ledger",
            "where": { "op": "gt", "path": "_.seq", "value": "slice.ledger_seq - 8" }
          }
        },
        {
          "op": "emit_event",
          "value": {
            "type": "payment_completed",
            "payload": {
              "debt_id": "event.debt_id",
              "to": "slice.debts.{event.debt_id}.creditor",
              "amount": "min(event.amount, slice.debts.{event.debt_id}.amount)",
              "debt_remaining": "slice.debts.{event.debt_id}.amount - min(event.amount, slice.debts.{event.debt_id}.amount)"
            }
          }
        },
        {
          "op": "dec",
          "path": "player.gold",
          "value": "min(event.amount, slice.debts.{event.debt_id}.amount)"
        },
        {
          "op": "dec",
          "path": "slice.debts.{event.debt_id}.amount",
          "value": "min(event.amount, slice.debts.{event.debt_id}.amount)"
        }
      ]
    },
    {
      "type": "debt_payment_offered",
      "when": {
        "all": [
          { "op": "has", "path": "event.debt_id" },
          { "op": "eq", "path": "slice.debts.{event.debt_id}.amount", "value": 0 }
        ]
      },
      "do": [
        { "op": "inc", "path": "slice.ledger_seq", "value": 1 },
        {
          "op": "push",
          "path": "slice.ledger",
          "value": {
            "seq": "slice.ledger_seq",
            "kind": "debt_settled",
            "amount": 0,
            "with": "slice.debts.{event.debt_id}.creditor",
            "note": "coalesce(event.reason, null)"
          }
        },
        {
          "op": "set",
          "path": "slice.ledger",
          "value": {
            "filter": "slice.ledger",
            "where": { "op": "gt", "path": "_.seq", "value": "slice.ledger_seq - 8" }
          }
        },
        {
          "op": "emit_event",
          "value": {
            "type": "debt_settled",
            "payload": {
              "debt_id": "event.debt_id",
              "creditor": "slice.debts.{event.debt_id}.creditor"
            }
          }
        },
        { "op": "remove", "path": "slice.debts.{event.debt_id}" }
      ]
    },
    {
      "type": "debt_forgiven",
      "when": {
        "all": [
          { "op": "has", "path": "event.debt_id" },
          { "op": "has", "path": "slice.debts.{event.debt_id}" }
        ]
      },
      "do": [
        { "op": "inc", "path": "slice.ledger_seq", "value": 1 },
        {
          "op": "push",
          "path": "slice.ledger",
          "value": {
            "seq": "slice.ledger_seq",
            "kind": "debt_forgiven",
            "amount": "slice.debts.{event.debt_id}.amount",
            "with": "slice.debts.{event.debt_id}.creditor",
            "note": "coalesce(event.reason, null)"
          }
        },
        {
          "op": "set",
          "path": "slice.ledger",
          "value": {
            "filter": "slice.ledger",
            "where": { "op": "gt", "path": "_.seq", "value": "slice.ledger_seq - 8" }
          }
        },
        { "op": "remove", "path": "slice.debts.{event.debt_id}" }
      ]
    }
  ],
  "events_produced": ["payment_completed", "payment_rejected", "gold_lost", "debt_settled"],
  "projections": [],
  "derived_views": [
    {
      "name": "wallet",
      "rule": { "gold": "player.gold", "open_debts": "len(slice.debts)" }
    },
    {
      "name": "open_debts",
      "rule": {
        "map": "slice.debts[*]",
        "to": {
          "id": "_.debt_id",
          "debtor": "_.debtor",
          "creditor": "_.creditor",
          "amount": "_.amount",
          "reason": "_.reason"
        }
      }
    },
    {
      "name": "recent_ledger",
      "rule": "slice.ledger"
    }
  ],
  "fixtures": [
    {
      "before": { "debts": {}, "ledger": [], "ledger_seq": 0 },
      "event": {
        "type": "gold_granted",
        "amount": 10,
        "from": "yuannes",
        "reason": "encargo del taller"
      },
      "context": { "player": { "gold": 0 } },
      "after": {
        "debts": {},
        "ledger": [
          { "seq": 1, "kind": "grant", "amount": 10, "with": "yuannes", "note": "encargo del taller" }
        ],
        "ledger_seq": 1
      }
    },
    {
      "before": { "debts": {}, "ledger": [], "ledger_seq": 0 },
      "event": { "type": "payment_offered", "amount": 6, "to": "yishaq" },
      "context": { "player": { "gold": 3 } },
      "after": {
        "debts": {},
        "ledger": [
          { "seq": 1, "kind": "payment_rejected", "amount": 6, "with": "yishaq", "note": null }
        ],
        "ledger_seq": 1
      }
    },
    {
      "before": {
        "debts": {
          "yishaq_6dineros": {
            "debt_id": "yishaq_6dineros",
            "debtor": "player",
            "creditor": "yishaq",
            "amount": 6,
            "reason": "préstamo de la feria de San Juan"
          }
        },
        "ledger": [],
        "ledger_seq": 0
      },
      "event": { "type": "debt_payment_offered", "debt_id": "yishaq_6dineros", "amount": 6 },
      "context": { "player": { "gold": 10 } },
      "after": {
        "debts": {},
        "ledger": [
          { "seq": 1, "kind": "debt_payment", "amount": 6, "with": "yishaq", "note": null },
          { "seq": 2, "kind": "debt_settled", "amount": 0, "with": "yishaq", "note": null }
        ],
        "ledger_seq": 2
      }
    },
    {
      "before": {
        "debts": {},
        "ledger": [
          { "seq": 1, "kind": "grant", "amount": 1, "with": null, "note": null },
          { "seq": 2, "kind": "grant", "amount": 1, "with": null, "note": null },
          { "seq": 3, "kind": "grant", "amount": 1, "with": null, "note": null },
          { "seq": 4, "kind": "grant", "amount": 1, "with": null, "note": null },
          { "seq": 5, "kind": "grant", "amount": 1, "with": null, "note": null },
          { "seq": 6, "kind": "grant", "amount": 1, "with": null, "note": null },
          { "seq": 7, "kind": "grant", "amount": 1, "with": null, "note": null },
          { "seq": 8, "kind": "grant", "amount": 1, "with": null, "note": null }
        ],
        "ledger_seq": 8
      },
      "event": { "type": "gold_stolen", "amount": 5, "by": "ladron" },
      "context": { "player": { "gold": 3 } },
      "after": {
        "debts": {},
        "ledger": [
          { "seq": 2, "kind": "grant", "amount": 1, "with": null, "note": null },
          { "seq": 3, "kind": "grant", "amount": 1, "with": null, "note": null },
          { "seq": 4, "kind": "grant", "amount": 1, "with": null, "note": null },
          { "seq": 5, "kind": "grant", "amount": 1, "with": null, "note": null },
          { "seq": 6, "kind": "grant", "amount": 1, "with": null, "note": null },
          { "seq": 7, "kind": "grant", "amount": 1, "with": null, "note": null },
          { "seq": 8, "kind": "grant", "amount": 1, "with": null, "note": null },
          { "seq": 9, "kind": "loss", "amount": 3, "with": "ladron", "note": null }
        ],
        "ledger_seq": 9
      }
    }
  ]
}
